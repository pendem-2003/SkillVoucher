// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

// ============ User Management ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  phone         String?
  company       String?
  designation   String?
  upiId         String?
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  enrollments   Enrollment[]
  payments      Payment[]
  courseRequests CourseRequest[]
  bookOrders    BookOrder[]
  bookRequests  BookRequest[]
  accounts      Account[]
  sessions      Session[]
  
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique // OTP code
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ============ Course Management ============

model Course {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String    @db.Text
  shortDesc     String?   @db.VarChar(200)
  thumbnail     String
  price         Float
  duration      Int       @default(90) // Duration in days (90 for 3 months)
  category      String
  level         String    // Beginner, Intermediate, Advanced
  language      String    @default("English")
  instructor    String?   // Instructor name
  whatYouLearn  String[]  // Array of learning outcomes
  prerequisites String[]  // Array of prerequisites
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  rating        Float?    @default(0)
  studentsCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  modules       Module[]
  enrollments   Enrollment[]
  reviews       Review[]
  
  @@map("courses")
}

model Module {
  id            String    @id @default(cuid())
  courseId      String
  title         String
  description   String?
  order         Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons       Lesson[]
  
  @@map("modules")
}

model Lesson {
  id            String    @id @default(cuid())
  moduleId      String
  title         String
  content       String    @db.Text // Theory content (Markdown supported)
  videoUrl      String?   // YouTube/external video URL
  videoType     String?   @default("youtube") // youtube, vimeo, custom
  duration      Int?      // Video duration in minutes
  order         Int
  isFree        Boolean   @default(false) // Preview lesson
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  module        Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress      LessonProgress[]
  
  @@map("lessons")
}

model Book {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String    @db.Text
  shortDesc     String?   @db.VarChar(200)
  author        String
  thumbnail     String
  price         Float
  category      String    // Programming, Business, Self-Help, Novel, etc.
  language      String    @default("English")
  pages         Int?
  publisher     String?
  publishedYear Int?
  isbn          String?
  rating        Float?    @default(4.5)
  ordersCount   Int       @default(0)
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  orders        BookOrder[]
  
  @@map("books")
}

model BookOrder {
  id                String    @id @default(cuid())
  userId            String
  bookId            String
  quantity          Int       @default(1)
  totalAmount       Float
  
  // Delivery Details
  deliveryName      String
  deliveryPhone     String
  deliveryEmail     String
  deliveryAddress   String    @db.Text
  deliveryCity      String
  deliveryState     String
  deliveryPincode   String
  deliveryLandmark  String?
  
  // Order Status
  orderStatus       OrderStatus @default(PROCESSING)
  paymentStatus     PaymentStatus @default(PENDING)
  trackingNumber    String?
  
  // Payment Details
  paymentMethod     String?   // Manual, Card
  paymentScreenshot String?   // For manual payments
  transactionId     String?
  upiId             String?   // User's UPI ID for refunds
  
  // Refund Details (same as courses)
  refundScreenshot  String?
  refundOfferSent   Boolean   @default(false)
  refundOfferUrl    String?
  refundOfferSentAt DateTime?
  
  notes             String?   @db.Text
  deliveredAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book              Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  @@map("book_orders")
}

model BookRequest {
  id            String    @id @default(cuid())
  userId        String
  bookName      String
  author        String?
  description   String    @db.Text
  category      String?
  expectedPrice Float?
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  status        RequestStatus @default(PENDING)
  adminNotes    String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("book_requests")
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ============ Enrollment & Progress ============

model Enrollment {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  startDate     DateTime  @default(now())
  endDate       DateTime  // startDate + 90 days
  isActive      Boolean   @default(true)
  progress      Int       @default(0) // 0-100
  lastAccessedAt DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  
  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id            String    @id @default(cuid())
  enrollmentId  String
  lessonId      String
  completed     Boolean   @default(false)
  watchedDuration Int     @default(0) // in seconds
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson        Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

// ============ Payment & Invoicing ============

model Payment {
  id                String    @id @default(cuid())
  userId            String
  courseId          String?
  amount            Float
  currency          String    @default("INR")
  status            PaymentStatus @default(PENDING)
  paymentMethod     String?   // UPI, Card, Wallet, NetBanking, Manual
  razorpayOrderId   String?   @unique
  razorpayPaymentId String?   @unique
  razorpaySignature String?
  invoiceNumber     String    @unique
  
  // Manual Payment Details
  paymentProofUrl   String?   // Screenshot/proof upload
  upiId             String?   // User's UPI ID for refunds
  userNote          String?   @db.Text // User's message/note
  adminNote         String?   @db.Text // Admin's response note
  verifiedAt        DateTime? // When admin verified
  verifiedBy        String?   // Admin user ID who verified
  rejectedAt        DateTime?
  rejectionReason   String?   @db.Text
  
  // Refund offer (60% cashback program)
  refundOfferSent   Boolean   @default(false) // Has admin sent 60% refund offer
  refundOfferUrl    String?   // Screenshot of 60% refund sent to user
  refundOfferSentAt DateTime? // When refund offer was sent
  
  // Refund details
  refundOption      RefundOption?
  refundAccount     String?   // Bank account or UPI ID
  refundMobile      String?
  
  // Additional details
  customerName      String
  customerEmail     String
  customerPhone     String?
  customerCompany   String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice           Invoice?
  
  @@map("payments")
}

model PaymentSettings {
  id          String   @id @default(cuid())
  upiId       String   // UPI ID for payments
  qrCodeUrl   String   // QR code image URL
  bankName    String?  // Optional bank details
  accountNo   String?
  ifscCode    String?
  accountName String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String   // Admin who updated
  
  @@map("payment_settings")
}

model Invoice {
  id                String    @id @default(cuid())
  invoiceNumber     String    @unique
  paymentId         String?   @unique  // Made optional for book orders
  userId            String
  
  // Invoice Details
  subtotal          Float
  taxRate           Float     @default(18) // GST rate in percentage
  taxAmount         Float
  totalAmount       Float
  
  // Customer Details (for reimbursement)
  customerName      String
  customerEmail     String
  customerPhone     String?
  customerCompany   String?
  customerAddress   String?
  
  // Courses purchased
  courseIds         String[]  // Array of course IDs
  courseDetails     Json      // Detailed course info with prices
  
  // Company Details (our company)
  companyName       String    @default("SkillVoucher Learning Pvt Ltd")
  companyAddress    String    @default("123 Business Park, Tech Hub, Bangalore - 560001")
  companyGSTIN      String    @default("29AAAAA0000A1Z5")
  companyEmail      String    @default("billing@skillvoucher.com")
  companyPhone      String    @default("+91 80 1234 5678")
  
  // Additional Info
  paymentMethod     String
  transactionId     String?
  notes             String?   @db.Text
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  payment           Payment?  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  @@map("invoices")
}

enum PaymentStatus {
  PENDING
  PENDING_REFUND  // Payment rejected, waiting for admin to send refund proof
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundOption {
  SAME_ACCOUNT
  MOBILE_NUMBER
  UPI_ID
}

// ============ Course Requests & Reviews ============

model CourseRequest {
  id            String    @id @default(cuid())
  userId        String
  courseName    String
  description   String    @db.Text
  category      String?
  expectedPrice Float?
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  status        RequestStatus @default(PENDING)
  adminNotes    String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("course_requests")
}

enum RequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

model Review {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  rating        Int       // 1-5
  comment       String?   @db.Text
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@map("reviews")
}

// ============ Notifications ============

model Notification {
  id            String    @id @default(cuid())
  userId        String?
  userEmail     String?
  title         String
  message       String    @db.Text
  type          String    // PAYMENT_APPROVED, PAYMENT_REJECTED, PAYMENT_PENDING, REFUND_PROCESSED, COMPLAINT_REPLY, etc.
  isRead        Boolean   @default(false)
  metadata      Json?     // Store refundScreenshot, adminMessage, complaintId, etc.
  createdAt     DateTime  @default(now())
  
  @@map("notifications")
}

model Support {
  id            String          @id @default(cuid())
  userId        String
  userEmail     String
  userName      String
  subject       String
  status        SupportStatus   @default(OPEN)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  messages      SupportMessage[]
  
  @@map("support_tickets")
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportMessage {
  id            String    @id @default(cuid())
  supportId     String
  senderId      String
  senderEmail   String
  senderName    String
  senderRole    Role      // USER or ADMIN
  message       String    @db.Text
  attachments   Json?     // Array of attachment URLs
  createdAt     DateTime  @default(now())
  
  support       Support   @relation(fields: [supportId], references: [id], onDelete: Cascade)
  
  @@map("support_messages")
}
